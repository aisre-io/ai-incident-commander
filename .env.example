# LLM - DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxxxx
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash

# Slack (optional, secondary)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxx

# Notifier selection: lark (default) | slack | console
NOTIFIER_TYPE=lark

# Lark/Feishu custom bot webhook (no App registration required)
# Get it: Lark group -> Settings -> Bots -> Add Bot -> Custom Bot -> Copy webhook URL
# The webhook URL contains the token after /hook/
LARK_WEBHOOK_URL=
LARK_REGION=cn  # cn = feishu.cn, intl = larksuite.com

# Supabase / PostgreSQL
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=xxxxx
DATABASE_URL=postgresql://postgres:xxxxx@xxxxx:5432/postgres

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxx

# PagerDuty (optional)
PAGERDUTY_API_KEY=xxxxx

# Opsgenie (optional)
OPSGENIE_API_KEY=xxxxx

# App
APP_ENV=development
LOG_LEVEL=DEBUG
